# -------------------------------------------------------
# FreeFuelPrice UK — Mobile App Environment Variables
# -------------------------------------------------------
# Copy this file to .env and fill in values.
#   cp .env.example .env
#
# Expo reads variables prefixed with EXPO_PUBLIC_ at build
# time and injects them into process.env on the client.
# -------------------------------------------------------

# API base URL (no trailing slash)
# Local development: point to your local backend
# Production: https://api.freefuelpriceapp.com
EXPO_PUBLIC_API_URL=https://api.freefuelpriceapp.com

# -------------------------------------------------------
# The variables below are NOT used by the mobile app at
# runtime but are documented here for reference so that
# a developer setting up the full stack knows what the
# backend expects. They live in AWS Secrets Manager for
# the production ECS deployment.
# -------------------------------------------------------

# (backend only) PostgreSQL connection
# DATABASE_URL=postgresql://user:pass@host:5432/fueluk

# (backend only) Ingestion API key for UKPIA/CMA data
# FUEL_DATA_API_KEY=

# (backend only) Push notification credentials
# EXPO_PUSH_ACCESS_TOKEN=
