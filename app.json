{
  "expo": {
    "name": "FreeFuelPrice UK",
    "slug": "fueluk-mobile-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.freefuelprice.uk",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "FreeFuelPrice uses your location to find nearby fuel stations."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.freefuelprice.uk",
      "permissions": ["ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION"]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "FreeFuelPrice uses your location to find nearby fuel stations."
        }
      ]
    ],
    "extra": {
      "apiBaseUrl": "https://api.freefuelprice.co.uk"
    }
  }
}
